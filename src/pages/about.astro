---
import BaseLayout from "../layouts/BaseLayout.astro";
import { links, site } from "../data/site";
---

<BaseLayout title={`About - ${site.name}`} description="About Zack Meacham.">
  <section class="shell-wide pt-14">
    <p class="mono-tag">About</p>
    <h1 class="mt-4 max-w-[14ch]">Engineer, builder, and systems-minded generalist.</h1>
    <div class="mt-6 max-w-[60ch] space-y-5">
      {site.aboutParagraphs.map((paragraph) => (
        <p class="prose-soft">{paragraph}</p>
      ))}
    </div>
  </section>

  <section class="shell-wide pt-16">
    <div class="about-grid">
      <div>
        <p class="mono-tag">Strengths</p>
        <ul class="rule mt-4 space-y-4 pt-6">
          {site.strengths.map((item) => (
            <li class="prose-soft">{item}</li>
          ))}
        </ul>
      </div>
      <div>
        <p class="mono-tag">Working style</p>
        <ul class="rule mt-4 space-y-4 pt-6">
          {site.workingStyle.map((item) => (
            <li class="prose-soft">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="shell-wide pt-16">
    <div class="about-grid">
      <div>
        <p class="mono-tag">Credibility</p>
        <ul class="rule mt-4 space-y-4 pt-6">
          {site.credibilityHighlights.map((item) => (
            <li class="prose-soft">{item}</li>
          ))}
        </ul>
      </div>
      <div>
        <p class="mono-tag">Links</p>
        <ul class="rule mt-4 space-y-4 pt-6">
          {links.map((item) => (
            <li class="prose-soft">
              <a href={item.href} target="_blank" rel="noreferrer" class="link">{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="shell-wide pt-16">
    <div class="personal-band">
      <p class="mono-tag">Outside work</p>
      <p class="prose-soft mt-4 max-w-[62ch]">{site.shortPersonal}</p>
    </div>
  </section>
</BaseLayout>
