---
import BaseLayout from "../layouts/BaseLayout.astro";
import { featured, personalProjects, proofPoints, site, workProjects } from "../data/site";
---

<BaseLayout title={site.title} description={site.description}>
  <section class="hero-band">
    <div class="shell-wide pt-10 pb-14 sm:pb-18">
      <div class="hero-grid">
        <div>
          <p class="mono-tag mono-tag--accent reveal">{site.roleLabel}</p>
          <h1 class="hero-title reveal reveal-1 mt-5">{site.name}</h1>
          <p class="lead reveal reveal-2 mt-6 max-w-[22ch]">{site.identitySentence}</p>
          <p class="prose-soft reveal reveal-3 mt-6 max-w-[60ch]">{site.homeSupport}</p>
          <p class="mono reveal reveal-4 mt-8 max-w-[72ch]">
            <span class="mono-tag">Now</span> {site.nowLine}
          </p>
          <div class="reveal reveal-4 mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-graphite">
            <a href="/projects" class="link">View projects</a>
            <a href="/resume" class="link">Open resume</a>
            <a href={site.email} class="link">Get in touch</a>
          </div>
        </div>

        <article class="feature-plane reveal reveal-4">
          <p class="mono-tag">{featured.eyebrow}</p>
          <div class="mt-8 flex items-start justify-between gap-4">
            <div>
              <h2>{featured.title}</h2>
              <p class="mono mt-2">{featured.year} · {featured.status}</p>
            </div>
            {featured.href && (
              <a href={featured.href} target="_blank" rel="noreferrer" class="mono link">Visit live</a>
            )}
          </div>
          <p class="prose-soft mt-5">{featured.summary}</p>
          <p class="prose-soft mt-4 text-sm">{featured.notes}</p>
          <p class="mono mt-6">{featured.stack.join(" · ")}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="shell-wide pt-8">
    <div class="proof-grid">
      {proofPoints.map((item) => (
        <div class="proof-item">
          <p class="proof-value">{item.value}</p>
          <p class="proof-label">{item.label}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="shell-wide pt-20">
    <div class="flex items-baseline justify-between gap-4">
      <div>
        <p class="mono-tag">Personal projects</p>
        <h2 class="mt-4 max-w-[16ch]">Modern software work outside the day job.</h2>
      </div>
      <a href="/projects" class="mono link">See all projects</a>
    </div>

    <ol class="project-list mt-8">
      {personalProjects.map((project) => (
        <li class="project-row">
          <div class="project-row-meta">
            <p class="mono-tag">{project.eyebrow}</p>
            <p class="mono">{project.year} · {project.status}</p>
          </div>
          <div class="project-row-body">
            <h3>{project.title}</h3>
            <p class="prose-soft mt-3">{project.summary}</p>
            <p class="prose-soft mt-3 text-sm">{project.notes}</p>
            <p class="mono mt-4">{project.stack.join(" · ")}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="shell-wide pt-20">
    <div class="flex items-baseline justify-between gap-4">
      <div>
        <p class="mono-tag">Boeing, public-safe</p>
        <h2 class="mt-4 max-w-[18ch]">High-stakes modernization work, written for the public web.</h2>
      </div>
      <a href="/about" class="mono link">Read more</a>
    </div>

    <div class="mt-8 grid gap-8 lg:grid-cols-3">
      {workProjects.map((project) => (
        <article class="work-plane">
          <p class="mono-tag">{project.status}</p>
          <h3 class="mt-4">{project.title}</h3>
          <p class="prose-soft mt-4 text-sm">{project.summary}</p>
          <p class="mono mt-5">{project.stack.join(" · ")}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell-wide pt-20">
    <div class="closing-band">
      <div>
        <p class="mono-tag">Outside work</p>
        <p class="prose-soft mt-4 max-w-[60ch]">{site.shortPersonal}</p>
      </div>
      <div class="closing-actions">
        <a href="/contact" class="button-link">Contact</a>
        {featured.href && (
          <a href={featured.href} target="_blank" rel="noreferrer" class="mono link">Ledger</a>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
