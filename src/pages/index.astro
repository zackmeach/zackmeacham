---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { heroActions, highlights, profileLinks, projects, site } from "../data/site";

const availableProfiles = profileLinks.filter((link) => link.href);
const heroLinks = [...heroActions, ...availableProfiles];
const featuredProjects = projects.slice(0, 3);
---

<BaseLayout title={site.title} description={site.description}>
  <section class="relative left-1/2 w-screen -translate-x-1/2 overflow-hidden border-y border-ink-900/10">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(22,33,48,0.06)_1px,transparent_1px),linear-gradient(to_bottom,rgba(22,33,48,0.06)_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:linear-gradient(to_bottom,white,transparent_86%)]"></div>
    <div class="shell relative grid gap-16 py-20 lg:grid-cols-[minmax(0,1.3fr)_20rem] lg:py-28">
      <div>
        <p class="eyebrow">{site.eyebrow}</p>
        <div class="mt-6 space-y-6">
          <p class="text-sm uppercase tracking-[0.3em] text-ink-700/75">{site.location}</p>
          <h1 class="max-w-4xl font-serif text-6xl leading-none text-ink-900 sm:text-7xl lg:text-[5.75rem]">
            {site.name}
          </h1>
          <p class="max-w-3xl text-2xl leading-tight text-ink-900 sm:text-3xl">
            {site.role}
          </p>
          <p class="section-copy">
            {site.summary}
          </p>
        </div>
        <div class="mt-10 flex flex-wrap gap-3">
          {heroLinks.map((link, index) => (
            <a
              href={link.href}
              class={`rounded-full px-5 py-3 text-sm font-semibold transition hover:-translate-y-0.5 ${
                index === 0
                  ? "bg-ink-900 text-cream-50 shadow-[0_16px_40px_rgba(22,33,48,0.18)]"
                  : "border border-ink-900/12 bg-white/70 text-ink-900"
              }`}
              target={link.external ? "_blank" : undefined}
              rel={link.external ? "noreferrer" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <aside class="self-end lg:pb-4">
        <p class="eyebrow">Launch Flow</p>
        <ol class="mt-6 space-y-8 border-l border-ink-900/15 pl-6 text-sm text-ink-700">
          <li>
            <p class="font-semibold text-ink-900">Build locally</p>
            <p class="mt-2 leading-7">Keep the first version tight: intro, projects, resume, and contact.</p>
          </li>
          <li>
            <p class="font-semibold text-ink-900">Deploy to Vercel</p>
            <p class="mt-2 leading-7">Ship a preview URL fast so changes stay visible and motivating.</p>
          </li>
          <li>
            <p class="font-semibold text-ink-900">Attach the domain</p>
            <p class="mt-2 leading-7">Point Porkbun DNS to Vercel once the preview feels strong.</p>
          </li>
        </ol>
      </aside>
    </div>
  </section>

  <section class="shell pt-18">
    <SectionHeading
      eyebrow="Selected Work"
      title="Project stories that can grow into a proper portfolio."
      intro="The cards below are structured for the portfolio story you described: what the project is, what problem it solved, what you built, and which tools you used."
    />
    <div class="mt-12 space-y-10">
      {featuredProjects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </section>

  <section class="shell pt-18">
    <SectionHeading
      eyebrow="How This Repo Is Set Up"
      title="Optimized for clarity, not ceremony."
      intro="The goal of this structure is to keep edits obvious: one content file, a few shared components, and pages that are easy to reason about when you want to improve them later."
    />
    <div class="mt-12 grid gap-10 lg:grid-cols-3">
      {highlights.map((item) => (
        <article class="border-t border-ink-900/12 pt-5">
          <h3 class="text-xl font-semibold text-ink-900">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-ink-700">{item.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="shell pt-18">
    <div class="border-t border-ink-900/12 py-12">
      <p class="eyebrow">Next Step</p>
      <div class="mt-5 grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-end">
        <div>
          <h2 class="max-w-3xl font-serif text-4xl text-ink-900 sm:text-5xl">
            Replace the starter copy with your real story, then push it live.
          </h2>
          <p class="section-copy mt-4">
            All of the editable copy lives in one place, so the next pass is mostly content work instead of framework work.
          </p>
        </div>
        <a
          href="/contact"
          class="inline-flex items-center justify-center rounded-full bg-coral-400 px-6 py-3 text-sm font-semibold text-ink-900 transition hover:-translate-y-0.5"
        >
          Open contact page
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
