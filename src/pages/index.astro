---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChipRow from "../components/ChipRow.astro";
import {
  flagshipProjects,
  hero,
  howIWork,
  proofStrip,
  site,
} from "../data/site";
---

<BaseLayout title={site.title} description={site.description}>
  <section class="hero-band">
    <div class="sheet-row pt-10 pb-16 sm:pb-20">
      <p class="sheet-row__label" aria-hidden="true"></p>
      <div class="sheet-row__body">
        <p class="mono-tag mono-tag--accent reveal">{hero.eyebrow}</p>
        <h1 class="hero-title reveal reveal-1 mt-5 max-w-[22ch]">{hero.headline}</h1>
        <p class="lead reveal reveal-2 mt-6 max-w-[60ch]">{hero.thesis}</p>
        <p class="hero-sub reveal reveal-3 mt-6 max-w-[62ch]">{hero.paragraph}</p>
        <div class="reveal reveal-3 mt-9 flex flex-wrap items-center gap-3 text-sm">
          <a href={hero.primaryCta.href} class="button-link">{hero.primaryCta.label}</a>
          <a href={hero.secondaryCta.href} class="button-link button-link--ghost">{hero.secondaryCta.label}</a>
        </div>
      </div>
      <svg class="dim-callout" aria-hidden="true" viewBox="0 0 60 200" preserveAspectRatio="none" focusable="false">
        <line class="dim-callout__line" x1="30" y1="4" x2="30" y2="196" />
        <line class="dim-callout__tick" x1="22" y1="4" x2="38" y2="4" />
        <line class="dim-callout__tick" x1="22" y1="196" x2="38" y2="196" />
      </svg>
      <span class="dim-callout__label" aria-hidden="true">applied AI · systems · product</span>
    </div>
  </section>

  <section id="proof" class="sheet-row pt-14 pb-2 scroll-mt-24">
    <p class="mono-tag mono-tag--accent sheet-row__label">Proof</p>
    <div class="sheet-row__body">
      <ul class="mt-6 grid gap-x-8 gap-y-7 sm:grid-cols-2 lg:grid-cols-4">
        {proofStrip.map((item) => (
          <li>
            <p class="mono-tag mono-tag--accent">{item.label}</p>
            <p class="prose-soft mt-3 max-w-[38ch]">{item.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section id="selected-work" class="sheet-row pt-20 scroll-mt-24">
    <p class="mono-tag sheet-row__label">Selected work</p>
    <div class="sheet-row__body">
      <div class="mt-4 flex items-baseline justify-between gap-4">
        <h2 class="max-w-[22ch]">Three flagship case studies.</h2>
        <a href="/work" class="mono link whitespace-nowrap">All work</a>
      </div>
      <ol class="project-list mt-8">
        {flagshipProjects.map((project) => (
          <li class="project-row">
            <div class="project-row-meta">
              <p class="mono-tag">{project.eyebrow}</p>
              <p class="mono mt-2">{project.meta}</p>
            </div>
            <div class="project-row-body">
              <h3 class="flagship-title">{project.title}</h3>
              <p class="prose-soft mt-3">{project.blurb}</p>
              <ChipRow chips={project.chips} class="mt-4" />
              <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-graphite">
                <a href={project.href} class="link font-medium text-ink">Read case study →</a>
                {project.repo && (
                  <a href={project.repo} target="_blank" rel="noreferrer" class="link">GitHub</a>
                )}
              </div>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section id="how-i-work" class="sheet-row pt-20 scroll-mt-24">
    <p class="mono-tag sheet-row__label">How I work</p>
    <div class="sheet-row__body">
      <h2 class="mt-4 max-w-[18ch]">{howIWork.heading}</h2>
      <ul class="mt-10 grid gap-x-10 gap-y-8 sm:grid-cols-2">
        {howIWork.pillars.map((p) => (
          <li class="max-w-[40ch]">
            <p class="mono-tag mono-tag--accent">{p.lead}</p>
            <p class="prose-soft mt-3 text-sm">{p.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section id="resume" class="sheet-row pt-20 scroll-mt-24">
    <p class="mono-tag sheet-row__label">Experience</p>
    <div class="sheet-row__body">
      <div class="mt-4 flex items-baseline justify-between gap-4">
        <h2 class="max-w-[22ch]">Full role history and skills.</h2>
        <a href="/resume" class="mono link whitespace-nowrap">Open resume</a>
      </div>
      <p class="prose-soft mt-6 max-w-[60ch]">Software Engineer 2 at Boeing since 2022 and cofounder and CTO at Ledger, with personal systems and tooling shipped alongside.</p>
    </div>
  </section>

  <section id="contact" class="sheet-row pt-20 pb-20 scroll-mt-24">
    <p class="mono-tag sheet-row__label">Contact</p>
    <div class="sheet-row__body">
      <div class="mt-4 flex items-baseline justify-between gap-4">
        <h2 class="max-w-[20ch]">Reach out.</h2>
        <a href="/contact" class="mono link whitespace-nowrap">Contact</a>
      </div>
      <p class="prose-soft mt-6 max-w-[55ch]">{site.contactIntro}</p>
      <div class="mt-8 flex flex-wrap items-center gap-3 text-sm">
        <a href="/contact" class="button-link">Get in touch</a>
        <a href={site.email} class="button-link button-link--ghost">Email</a>
      </div>
    </div>
  </section>
</BaseLayout>
