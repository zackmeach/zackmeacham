---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChipRow from "../components/ChipRow.astro";
import { educationEntries, links, resumeEntries, site, skillGroups } from "../data/site";
---

<BaseLayout title={`Resume - ${site.name}`} description="Resume for Zack Meacham.">
  <section class="shell-wide pt-14">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_18rem] lg:items-end">
      <div>
        <p class="mono-tag">Resume</p>
        <h1 class="mt-4">Zack Meacham</h1>
        <p class="prose-soft mt-4 max-w-[60ch]">{site.resumeSummary}</p>
      </div>

      <div class="resume-links print:hidden">
        <button type="button" data-print-resume class="button-link">Save as PDF</button>
        <p class="mono mt-3">{site.emailDisplay}</p>
        <p class="mono">{site.location}</p>
        {links.map((item) => (
          <a href={item.href} target="_blank" rel="noreferrer" class="mono link">{item.label}</a>
        ))}
      </div>
    </div>
  </section>

  <section class="shell-wide pt-14">
    <p class="mono-tag">Experience</p>
    <div class="mt-4">
      {resumeEntries.map((entry) => (
        <article class="resume-entry rule py-8">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <div>
              <h2>{entry.role}</h2>
              <p class="mono mt-1">{entry.organization}</p>
              {entry.previousRoles && (
                <p class="mono mt-1 text-graphite">{entry.previousRoles}</p>
              )}
            </div>
            <p class="mono whitespace-nowrap">{entry.period}</p>
          </div>
          <ul class="mt-4 space-y-2">
            {entry.bullets.map((bullet) => (
              <li class="prose-soft text-sm">{bullet}</li>
            ))}
          </ul>
          <ChipRow chips={entry.chips} class="mt-4" />
        </article>
      ))}
    </div>
  </section>

  <section class="shell-wide pt-14">
    <p class="mono-tag">Education</p>
    <div class="mt-4">
      {educationEntries.map((entry) => (
        <article class="resume-entry rule py-8">
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <div>
              <h2>{entry.institution}</h2>
              <p class="mono mt-1">{entry.credential}</p>
            </div>
            <p class="mono whitespace-nowrap">{entry.period}</p>
          </div>
          <ul class="mt-4 space-y-2">
            {entry.details.map((detail) => (
              <li class="prose-soft text-sm">{detail}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="shell-wide pt-14">
    <p class="mono-tag">Skills</p>
    <dl class="rule mt-4 grid gap-x-6 gap-y-5 pt-6 sm:grid-cols-[10rem_1fr]">
      {skillGroups.map((group) => (
        <>
          <dt class="mono">{group.label}</dt>
          <dd class="text-sm text-ink-soft">{group.items.join(" · ")}</dd>
        </>
      ))}
    </dl>
  </section>

  <script>
    document.querySelector("[data-print-resume]")?.addEventListener("click", () => {
      window.print();
    });
  </script>
</BaseLayout>
