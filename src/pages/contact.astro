---
import BaseLayout from "../layouts/BaseLayout.astro";
import { links, site } from "../data/site";
---

<BaseLayout title={`Contact - ${site.name}`} description="Contact Zack Meacham.">
  <section class="shell-wide pt-14">
    <p class="mono-tag">Contact</p>
    <h1 class="mt-4">Say hello.</h1>
    <p class="prose-soft mt-4 max-w-[56ch]">{site.contactIntro}</p>
  </section>

  <section class="shell-wide pt-10">
    <dl class="rule contact-grid pt-6">
      <dt class="mono">Email</dt>
      <dd><a href={site.email} class="link">{site.emailDisplay}</a></dd>

      {links.map((link) => (
        <>
          <dt class="mono">{link.label}</dt>
          <dd><a href={link.href} target="_blank" rel="noreferrer" class="link">{link.href.replace(/^https?:\/\//, "")}</a></dd>
        </>
      ))}

      <dt class="mono">Based</dt>
      <dd class="text-ink-soft">{site.location}</dd>
    </dl>
  </section>
</BaseLayout>
