---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectDetailLayout from "../../components/ProjectDetailLayout.astro";
import { projectDetails, site, type Project } from "../../data/site";

export function getStaticPaths() {
  const flagshipMeta: Record<string, Project> = {
    ledger: {
      slug: "ledger",
      kind: "personal",
      eyebrow: "Flagship · applied AI product",
      title: "Ledger / Vera",
      year: "2026",
      status: "Pre-Alpha",
      summary: "",
      notes: "",
      stack: [],
    },
    milodex: {
      slug: "milodex",
      kind: "personal",
      eyebrow: "Flagship · independent systems",
      title: "Milodex",
      year: "2026",
      status: "Active build",
      summary: "",
      notes: "",
      stack: [],
      repo: "https://github.com/zackmeach/Milodex",
    },
    boeing: {
      slug: "boeing",
      kind: "work",
      eyebrow: "Flagship · professional engineering",
      title: "Test Infrastructure at Boeing",
      year: "2022 – present",
      status: "Three concurrent efforts",
      summary: "",
      notes: "",
      stack: [],
    },
    "msm-awakening-tracker": {
      slug: "msm-awakening-tracker",
      kind: "personal",
      eyebrow: "Personal project · desktop",
      title: "MSM Awakening Tracker",
      year: "2026",
      status: "Shipped · v1.0.2",
      summary: "",
      notes: "",
      stack: [],
    },
  };

  return projectDetails.map((detail) => ({
    params: { slug: detail.slug },
    props: { project: flagshipMeta[detail.slug], detail },
  }));
}

const { project, detail } = Astro.props;

---

<BaseLayout title={`${project.title} · ${site.name}`} description={detail.lead}>
  <ProjectDetailLayout project={project} detail={detail} />
</BaseLayout>
