---
export type RailItem = {
  id: string;
  label: string;
  evidence?: string;
  href: string;
  note?: string;
};

export type ContextRailVariant = "thesis" | "case-index" | "case-structure" | "through-line";

interface Props {
  heading: string;
  subheading?: string;
  items: RailItem[];
  footerNote?: string;
  variant?: ContextRailVariant;
}

const { heading, subheading, items, footerNote, variant = "thesis" } = Astro.props;
---

<nav class="context-rail" aria-label="Page context" data-rail-variant={variant}>
  <div class="context-rail__inner">
    <p class="mono-tag context-rail__heading">{heading}</p>
    {subheading && <p class="context-rail__sub">{subheading}</p>}
    <ol class="context-rail__list">
      {items.map((item, i) => {
        const isAnchor = item.href.startsWith("#");
        return (
          <li>
            <a
              href={item.href}
              class="context-rail__link"
              data-rail-target={isAnchor ? item.href.slice(1) : undefined}
            >
              <span class="context-rail__index">{String(i + 1).padStart(2, "0")}</span>
              <span class="context-rail__body">
                <span class="context-rail__label">{item.label}</span>
                {item.evidence && (
                  <span class="context-rail__evidence">{item.evidence}</span>
                )}
                {item.note && (
                  <span class="context-rail__note">{item.note}</span>
                )}
              </span>
            </a>
          </li>
        );
      })}
    </ol>
    {footerNote && <p class="context-rail__footer">{footerNote}</p>}
  </div>
</nav>

<script>
  (function () {
    const rails = document.querySelectorAll<HTMLElement>(".context-rail");
    if (!rails.length) return;
    const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    rails.forEach((rail) => {
      const links = Array.from(
        rail.querySelectorAll<HTMLAnchorElement>("a[data-rail-target]")
      );
      const linkByTarget = new Map<HTMLElement, HTMLAnchorElement>();
      const targets: HTMLElement[] = [];
      links.forEach((link) => {
        const id = link.dataset.railTarget;
        if (!id) return;
        const el = document.getElementById(id);
        if (el) {
          targets.push(el);
          linkByTarget.set(el, link);
        }
      });

      const allLinks = Array.from(
        rail.querySelectorAll<HTMLAnchorElement>(".context-rail__link")
      );
      let active: HTMLAnchorElement | null = null;
      const setActive = (link: HTMLAnchorElement | null) => {
        if (link === active) return;
        allLinks.forEach((l) => l.removeAttribute("aria-current"));
        active = link;
        if (active) active.setAttribute("aria-current", "true");
      };

      // Default: first link softly active
      setActive(allLinks[0] ?? null);

      if (targets.length) {
        const visible = new Set<HTMLElement>();
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) visible.add(e.target as HTMLElement);
              else visible.delete(e.target as HTMLElement);
            });
            let topmost: HTMLElement | null = null;
            let topY = Infinity;
            visible.forEach((el) => {
              const r = el.getBoundingClientRect();
              if (r.top < topY) {
                topY = r.top;
                topmost = el;
              }
            });
            if (topmost) {
              const link = linkByTarget.get(topmost);
              setActive(link ?? allLinks[0] ?? null);
            } else {
              setActive(allLinks[0] ?? null);
            }
          },
          { rootMargin: "-20% 0px -65% 0px", threshold: 0 }
        );
        targets.forEach((t) => observer.observe(t));
      }

      if (!prefersReduced) {
        links.forEach((link) => {
          link.addEventListener("click", (e) => {
            const id = link.dataset.railTarget;
            if (!id) return;
            const target = document.getElementById(id);
            if (!target) return;
            e.preventDefault();
            target.scrollIntoView({ behavior: "smooth", block: "start" });
            history.replaceState(null, "", link.getAttribute("href")!);
          });
        });
      }
    });
  })();
</script>
