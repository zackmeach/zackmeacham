---
import type { Project } from "../data/site";

interface Props {
  project: Project;
}

const { project } = Astro.props;
const projectLinks = [
  project.href ? { label: "Open live project", href: project.href } : undefined,
  project.repo ? { label: "View repository", href: project.repo } : undefined,
].filter((link): link is { label: string; href: string } => Boolean(link));
---

<article class="border-t border-ink-900/12 pt-6">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div class="max-w-3xl">
      <p class="eyebrow">{project.status}</p>
      <h3 class="mt-3 text-2xl font-semibold text-ink-900 sm:text-3xl">{project.title}</h3>
      <p class="mt-3 text-base leading-8 text-ink-700">{project.summary}</p>
    </div>

    {projectLinks.length > 0 && (
      <div class="flex flex-wrap gap-3 lg:justify-end">
        {projectLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noreferrer"
            class="rounded-full border border-ink-900/12 px-4 py-2 text-sm font-semibold text-ink-900"
          >
            {link.label}
          </a>
        ))}
      </div>
    )}
  </div>

  <dl class="mt-8 grid gap-6 md:grid-cols-3">
    <div>
      <dt class="text-sm font-semibold text-ink-900">Problem</dt>
      <dd class="mt-2 text-sm leading-7 text-ink-700">{project.problem}</dd>
    </div>
    <div>
      <dt class="text-sm font-semibold text-ink-900">Built</dt>
      <dd class="mt-2 text-sm leading-7 text-ink-700">{project.build}</dd>
    </div>
    <div>
      <dt class="text-sm font-semibold text-ink-900">Impact</dt>
      <dd class="mt-2 text-sm leading-7 text-ink-700">{project.impact}</dd>
    </div>
  </dl>

  <ul class="mt-6 flex flex-wrap gap-2">
    {project.stack.map((item) => (
      <li class="rounded-full border border-ink-900/12 bg-white/70 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-ink-700">
        {item}
      </li>
    ))}
  </ul>
</article>
