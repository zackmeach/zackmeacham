---
import { navigation, site } from "../data/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
---

<header class="sticky top-0 z-50">
  <div class="shell pt-6">
    <div class="flex flex-col gap-4 rounded-full border border-ink-900/10 bg-white/75 px-4 py-3 shadow-[0_18px_45px_rgba(22,33,48,0.08)] backdrop-blur sm:flex-row sm:items-center sm:justify-between">
      <a href="/" class="flex items-center gap-3 text-sm text-ink-900">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-ink-900 text-xs font-semibold uppercase tracking-[0.24em] text-cream-50">
          ZM
        </span>
        <span>
          <span class="block font-semibold">{site.name}</span>
          <span class="block text-xs uppercase tracking-[0.28em] text-ink-700/75">zackmeacham.com</span>
        </span>
      </a>

      <nav aria-label="Primary" class="flex flex-wrap gap-1">
        {navigation.map((item) => (
          <a
            href={item.href}
            class={`rounded-full px-3 py-2 text-sm transition ${
              currentPath === item.href
                ? "bg-ink-900 text-cream-50"
                : "text-ink-700 hover:bg-ink-900/6 hover:text-ink-900"
            }`}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
