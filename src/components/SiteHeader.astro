---
import { navigation, site } from "../data/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header class="shell pt-10 pb-2">
  <div class="flex items-baseline justify-between gap-6">
    <a href="/" class="text-[0.95rem] font-medium tracking-tight text-ink">
      {site.name}
      <span class="mono ml-2">/ software engineer</span>
    </a>
    <nav aria-label="Primary" class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-graphite">
      {navigation.slice(1).map((item) => (
        <a
          href={item.href}
          class="nav-link hover:text-ink transition-colors"
          data-active={isActive(item.href) ? "true" : "false"}
        >
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>
