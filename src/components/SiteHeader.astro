---
import { navigation, site } from "../data/site";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function isActive(href: string) {
  if (href === "/") return currentPath === "/";
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header class="shell pt-10 pb-2">
  <div class="flex items-baseline justify-between gap-6">
    <a href="/" class="text-[0.95rem] font-medium tracking-tight text-ink">
      {site.name}
      <span class="mono ml-2">/ software engineer</span>
    </a>
    <nav aria-label="Primary" class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-graphite">
      {navigation.slice(1).map((item) => (
        <a
          href={item.href}
          class="nav-link hover:text-ink transition-colors"
          data-active={isActive(item.href) ? "true" : "false"}
        >
          {item.label}
        </a>
      ))}
      <button type="button" class="theme-toggle" data-theme-toggle aria-label="Toggle color theme">
        <span class="theme-toggle__icon theme-toggle__icon--moon" aria-hidden="true">☾</span>
        <span class="theme-toggle__icon theme-toggle__icon--sun" aria-hidden="true">☼</span>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  document.addEventListener("click", function (event) {
    var target = event.target;
    if (!target || !target.closest || !target.closest("[data-theme-toggle]")) return;
    var root = document.documentElement;
    var next = root.dataset.theme === "dark" ? "light" : "dark";
    root.dataset.theme = next;
    try {
      localStorage.setItem("theme", next);
    } catch (e) {}
  });
</script>
