---
import { links, site } from "../data/site";

const year = new Date().getFullYear();
const lastUpdated = new Date().toISOString().slice(0, 10);
---

<footer class="shell pt-20 pb-10">
  <div class="rule flex flex-col gap-4 pt-6 sm:flex-row sm:items-end sm:justify-between">
    <div class="mono">
      <span>{site.name.toLowerCase().replace(" ", "-")}.com</span>
      <span class="px-2">·</span>
      <span>last updated {lastUpdated}</span>
      <span class="px-2">·</span>
      <span>© {year}</span>
    </div>
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-graphite">
      <a href={site.email} class="hover:text-ink transition-colors">Email</a>
      {links.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer" class="hover:text-ink transition-colors">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
