---
import { profileLinks, site } from "../data/site";

const activeProfiles = profileLinks.filter((link) => link.href);
const year = new Date().getFullYear();
---

<footer class="shell pb-10 pt-16">
  <div class="border-t border-ink-900/10 pt-6 sm:flex sm:items-end sm:justify-between">
    <div>
      <p class="text-sm font-semibold text-ink-900">{site.name}</p>
      <p class="mt-2 text-sm text-ink-700">
        Built with Astro, styled with Tailwind, and ready for Vercel deployment.
      </p>
    </div>

    <div class="mt-5 flex flex-wrap items-center gap-4 text-sm text-ink-700 sm:mt-0">
      {activeProfiles.map((link) => (
        <a href={link.href} target="_blank" rel="noreferrer" class="hover:text-ink-900">
          {link.label}
        </a>
      ))}
      <a href={site.email} class="hover:text-ink-900">Email</a>
      <span>© {year}</span>
    </div>
  </div>
</footer>
