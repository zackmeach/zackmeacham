---
import type { Project, ProjectDetail } from "../data/site";
import { flagshipProjects } from "../data/site";
import ChipRow from "./ChipRow.astro";
import MilodexDiagram from "./MilodexDiagram.astro";

interface Props {
  project: Project;
  detail: ProjectDetail;
}

const { project, detail } = Astro.props;

// Carry the reader to the next flagship sheet in order. Non-flagship (archive)
// pages and the last flagship have no successor and just show the back link.
const flagshipIdx = flagshipProjects.findIndex((p) => p.slug === project.slug);
const nextFlagship =
  flagshipIdx >= 0 && flagshipIdx < flagshipProjects.length - 1
    ? flagshipProjects[flagshipIdx + 1]
    : null;
---

<article class="detail-sheet pt-14 pb-24">
  <header class="detail-row">
    <p class="mono-tag detail-row__label">{project.eyebrow}</p>
    <div class="detail-row__body">
      <h1 class="hero-title hero-title--detail max-w-[26ch]">{detail.detailTitle}</h1>
      <p class="mono mt-3">{project.year} · {project.status}</p>
      <p class="lead mt-6 max-w-[60ch]">{detail.lead}</p>
      <ChipRow chips={detail.topChips} class="mt-6" />
      {project.href && (
        <p class="mono mt-4">
          <a href={project.href} target="_blank" rel="noreferrer" class="link">Visit link</a>
        </p>
      )}
    </div>
  </header>

  <section id="at-a-glance" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">At a glance</p>
    <div class="detail-row__body">
      <dl class="grid gap-x-8 gap-y-3 sm:grid-cols-[auto_1fr]">
        {detail.glance.map((row) => (
          <>
            <dt class="mono">{row.label}</dt>
            <dd class="prose-soft" set:html={row.value} />
          </>
        ))}
      </dl>
    </div>
  </section>

  <section id="why-this-mattered" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">Why this mattered</p>
    <div class="detail-row__body">
      <p class="prose-soft">{detail.whyThisMattered}</p>
    </div>
  </section>

  <section id="role-and-ownership" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">My role and ownership</p>
    <div class="detail-row__body">
      <p class="prose-soft">{detail.roleAndOwnership}</p>
    </div>
  </section>

  <section id="core-constraints" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">Core constraints</p>
    <div class="detail-row__body">
      <ul class="space-y-3">
        {detail.coreConstraints.map((c) => (
          <li class="prose-soft text-sm">{c}</li>
        ))}
      </ul>
    </div>
  </section>

  <section id="architecture-and-key-decisions" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">Architecture and key decisions</p>
    <div class="detail-row__body">
      {project.slug === "milodex" && <MilodexDiagram />}
      <div class="space-y-10">
        {detail.architecture.map((s) => (
          <div>
            <h3>{s.title}</h3>
            <p class="prose-soft mt-3">{s.description}</p>
            <ChipRow chips={s.chips} class="mt-4" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="execution-highlights" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">Execution highlights</p>
    <div class="detail-row__body">
      <ul class="space-y-3">
        {detail.execution.map((e) => (
          <li class="prose-soft text-sm">{e}</li>
        ))}
      </ul>
    </div>
  </section>

  <section id="impact-current-state" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">Impact / current state</p>
    <div class="detail-row__body">
      <p class="prose-soft">{detail.currentState}</p>
    </div>
  </section>

  <section id="what-this-demonstrates" class="detail-row mt-14 scroll-mt-24">
    <p class="mono-tag detail-row__label">What this demonstrates</p>
    <div class="detail-row__body">
      <p class="lead">{detail.whatThisDemonstrates}</p>
    </div>
  </section>

  {detail.publicSafeNote && (
    <section class="detail-row mt-14">
      <p class="detail-row__label" aria-hidden="true"></p>
      <div class="detail-row__body">
        <p class="mono text-graphite">{detail.publicSafeNote}</p>
      </div>
    </section>
  )}

  <section class="detail-row mt-14">
    <p class="detail-row__label" aria-hidden="true"></p>
    <div class="detail-row__body flex flex-wrap items-baseline justify-between gap-x-6 gap-y-2">
      <a href="/work" class="mono link">← All work</a>
      {nextFlagship && (
        <a href={nextFlagship.href} class="mono link print:hidden">Next sheet → {nextFlagship.title}</a>
      )}
    </div>
  </section>
</article>
